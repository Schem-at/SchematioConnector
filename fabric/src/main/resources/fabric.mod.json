{
  "schemaVersion": 1,
  "id": "schematioconnector",
  "version": "${version}",
  "name": "Schematio Connector",
  "description": "Upload and download schematics from schemat.io",
  "authors": [
    "Schemat.io Team"
  ],
  "contact": {
    "homepage": "https://schemat.io",
    "sources": "https://github.com/schemat-io/SchematioConnector"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "io.schemat.connector.fabric.SchematioConnectorMod"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "io.schemat.connector.fabric.client.SchematioClientMod"
      }
    ]
  },
  "mixins": [
    {
      "config": "schematioconnector.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_min}",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=${flk_min}",
    "conditional-mixin": ">=0.6.0",
    "minecraft": "${minecraft_compat}",
    "java": ">=${java_version}"
  },
  "suggests": {
    "worldedit": "*"
  }
}
